{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Jobs"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Total Jobs",
        "view": "singleValue",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SUM(SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName} MetricName=\"jobscheduler_job_count_total\" AND Namespace=\"simphera\"', 'Maximum', 60))",
              "id": "total_jobs",
              "label": "Total Jobs",
              "period": 60
            }
          ]
        ],
        "sparkline": true
      }
    },
    {
      "type": "log",
      "x": 6,
      "y": 1,
      "width": 9,
      "height": 6,
      "properties": {
        "title": "Job States (raw logs)",
        "region": "eu-central-1",
        "view": "timeSeries",
        "query": "SOURCE '/aws/containerinsights/mariog-simphera/prometheus' | fields @timestamp, jobscheduler_job_count_total, state\n| filter ispresent(jobscheduler_job_count_total) and ispresent(state)\n| stats max(jobscheduler_job_count_total) by bin(1m), state"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 7,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Job States (CloudWatch)",
        "view": "bar",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "m_pending + m_processing + m_blocked + m_deleting",
              "id": "total",
              "label": "TOTAL"
            }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "PENDING",
            {
              "id": "m_pending",
              "label": "PENDING",
              "stat": "Sum",
              "period": 60
            }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "PROCESSING",
            {
              "id": "m_processing",
              "label": "PROCESSING",
              "stat": "Sum",
              "period": 60
            }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "BLOCKED",
            {
              "id": "m_blocked",
              "label": "BLOCKED",
              "stat": "Sum",
              "period": 60
            }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "DELETING",
            {
              "id": "m_deleting",
              "label": "DELETING",
              "stat": "Sum",
              "period": 60
            }
          ]
        ],
        "legend": {
          "position": "right"
        }
      }
    },
    {
      "type": "metric",
      "x": 6,
      "y": 7,
      "width": 9,
      "height": 6,
      "properties": {
        "title": "Job States (CloudWatch Timeseries)",
        "region": "eu-central-1",
        "view": "timeSeries",
        "stat": "Sum",
        "period": 60,
        "metrics": [
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "PENDING",
            { "id": "m_pending", "label": "PENDING" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "PROCESSING",
            { "id": "m_processing", "label": "PROCESSING" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "DELETING",
            { "id": "m_deleting", "label": "DELETING" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "BLOCKED",
            { "id": "m_blocked", "label": "BLOCKED" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "ERROR",
            { "id": "m_error", "label": "ERROR" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "EXECUTED",
            { "id": "m_executed", "label": "EXECUTED" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "ABORTED",
            { "id": "m_aborted", "label": "ABORTED" }
          ],
          [
            "simphera",
            "jobscheduler_job_count_total",
            "state",
            "ABORTING",
            { "id": "m_aborting", "label": "ABORTING" }
          ]
        ],
        "legend": {
          "position": "bottom"
        }
      }
    },
    {
      "type": "metric",
      "x": 15,
      "y": 1,
      "width": 9,
      "height": 12,
      "properties": {
        "title": "Total Execution Time",
        "region": "eu-central-1",
        "view": "bar",
        "stat": "Sum",
        "period": 60,
        "metrics": [
          [
            "simphera",
            "jobexecutor_method_duration_seconds_sum",
            "method",
            "Simulate",
            { "id": "m_simulate", "label": "Simulate" }
          ],
          [
            "simphera",
            "jobexecutor_method_duration_seconds_sum",
            "method",
            "Total",
            { "id": "m_total", "label": "Total" }
          ],
          [
            {
              "expression": "m_total - m_simulate",
              "id": "m_other",
              "label": "Other"
            }
          ]
        ],
        "legend": {
          "position": "right"
        }
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 13,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Agents"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 14,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Total Agents",
        "view": "singleValue",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SUM(SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName} MetricName=\"jobscheduler_executor_count_total\" AND Namespace=\"simphera\"', 'Maximum', 60))",
              "id": "total_agents",
              "label": "Total Agents",
              "period": 60
            }
          ]
        ],
        "period": 300,
        "sparkline": true
      }
    },
    {
      "type": "metric",
      "x": 6,
      "y": 14,
      "width": 9,
      "height": 6,
      "properties": {
        "title": "Agents by Agent Pool",
        "region": "eu-central-1",
        "view": "timeSeries",
        "stat": "Sum",
        "period": 60,
        "metrics": [
          [
            "simphera",
            "jobscheduler_running_agent_count_total",
            "agentpool",
            "*",
            { "label": "$${PROP('Dim.agentpool')}", "id": "m_pool" }
          ]
        ],
        "legend": {
          "position": "bottom"
        }
      }
    },
    {
      "type": "metric",
      "x": 15,
      "y": 14,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Agent States",
        "region": "eu-central-1",
        "view": "bar",
        "stat": "Sum",
        "period": 60,
        "metrics": [
          [
            { "expression": "m_idle + m_proc", "id": "total", "label": "Total" }
          ],
          [
            "simphera",
            "jobscheduler_executor_count_total",
            "state",
            "Idle",
            { "id": "m_idle", "label": "Idle" }
          ],
          [
            "simphera",
            "jobscheduler_executor_count_total",
            "state",
            "Processing",
            { "id": "m_proc", "label": "Processing" }
          ]
        ],
        "legend": {
          "position": "right"
        }
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 20,
      "width": 9,
      "height": 6,
      "properties": {
        "title": "Agent States (raw logs)",
        "region": "eu-central-1",
        "view": "timeSeries",
        "query": "SOURCE '/aws/containerinsights/mariog-simphera/prometheus' | fields @timestamp, jobscheduler_executor_count_total, state\n| filter ispresent(jobscheduler_executor_count_total) and ispresent(state)\n| stats max(jobscheduler_executor_count_total) by bin(1m), state"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 26,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Min Agent Count (by agentpool)",
        "view": "bar",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName,agentpool} MetricName=\"jobscheduler_min_agent_count_total\" AND Namespace=\"simphera\"', 'Maximum', 60)",
              "id": "min_agents",
              "label": "$${PROP('Dim.agentpool')}",
              "period": 60
            }
          ]
        ],
        "setPeriodToTimeRange": true,
        "stacked": false
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 26,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Max Agent Count (by agentpool)",
        "view": "bar",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName,agentpool} MetricName=\"jobscheduler_max_agent_count_total\" AND Namespace=\"simphera\"', 'Maximum', 60)",
              "id": "max_agents",
              "label": "$${PROP('Dim.agentpool')}",
              "period": 60
            }
          ]
        ],
        "setPeriodToTimeRange": true
      }
    },
    {
      "type": "metric",
      "x": 9,
      "y": 20,
      "width": 8,
      "height": 6,
      "properties": {
        "metrics": [
          [
            {
              "expression": "SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName,agentpool} MetricName=\"jobscheduler_running_agent_count_total\" AND Namespace=\"simphera\"', 'Minimum', 60)",
              "id": "running_agents",
              "label": "$${PROP('Dim.agentpool')}",
              "period": 60,
              "region": "eu-central-1",
              "stat": "Minimum"
            }
          ]
        ],
        "title": "Running Agent Count (by agentpool)",
        "view": "bar",
        "region": "eu-central-1",
        "setPeriodToTimeRange": true,
        "period": 60,
        "stat": "Minimum"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 32,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Executor agent"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 33,
      "width": 8,
      "height": 8,
      "properties": {
        "view": "timeSeries",
        "region": "eu-central-1",
        "stacked": true,
        "title": "Execution Time",
        "period": 60,
        "stat": "Sum",
        "legend": {
          "position": "bottom"
        },
        "metrics": [
          [
            "JobExecutor",
            "MethodDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Method",
            "Simulate",
            { "label": "Simulate", "color": "#2d8745" }
          ],
          [
            "JobExecutor",
            "MethodDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Method",
            "OtherMethod1",
            { "label": "OtherMethod1" }
          ],
          [
            "JobExecutor",
            "PluginDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            { "id": "plugins", "label": "Plugins", "color": "#888888" }
          ],
          [
            "JobExecutor",
            "MethodDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Method",
            "Total",
            {
              "id": "total",
              "label": "Total",
              "color": "#8b0000",
              "stat": "Sum"
            }
          ],
          [
            {
              "expression": "total - SUM(METRICS('MethodDurationSecondsSum')) - plugins",
              "label": "Other",
              "color": "#a0a0a0",
              "id": "other"
            }
          ]
        ]
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 33,
      "width": 8,
      "height": 8,
      "properties": {
        "view": "timeSeries",
        "region": "eu-central-1",
        "stacked": false,
        "title": "Plugins Duration Time",
        "period": 60,
        "stat": "Sum",
        "legend": {
          "position": "bottom"
        },
        "metrics": [
          [
            "JobExecutor",
            "PluginDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Plugin",
            "PluginA",
            { "label": "PluginA" }
          ],
          [
            "JobExecutor",
            "PluginDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Plugin",
            "PluginB",
            { "label": "PluginB" }
          ],
          [{ "id": "total", "expression": "SUM(METRICS())", "label": "Total" }]
        ]
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 33,
      "width": 8,
      "height": 8,
