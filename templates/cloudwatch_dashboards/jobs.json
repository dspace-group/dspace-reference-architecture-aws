{
  "variables": [
    {
      "type": "pattern",
      "pattern": "agent_pod_name",
      "inputType": "select",
      "id": "Pod",
      "label": "Pod",
      "visible": true,
      "inputPopulationType": "search",
      "search": "{ContainerInsights/Prometheus,Namespace,PodName,ServiceName}",
      "populateFrom": "PodName"
    }
  ],
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Jobs"
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 28,
      "width": 24,
      "height": 11,
      "properties": {
        "query": "SOURCE \"/aws/containerinsights/simphera-sk/application\" |\nfilter kubernetes.namespace_name=\"simphera\" | filter @logStream like /agent_pod_name/ | fields jsonParse(@message) as js  | fields js.time as TimeStamp, js.log as LogMessage | sort TimeStamp desc | display TimeStamp, LogMessage | limit 100",
        "queryBy": "logGroupName",
        "logGroupPrefixes": {
          "logClass": "STANDARD",
          "logGroupPrefix": [],
          "accountIds": []
        },
        "region": "eu-central-1",
        "stacked": false,
        "title": "Job States (raw logs)",
        "view": "table"
      }
    },
    {
