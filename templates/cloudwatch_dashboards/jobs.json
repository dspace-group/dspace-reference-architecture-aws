        "period": 60,
        "stat": "Sum",
        "legend": {
          "position": "bottom"
        },
        "metrics": [
          [
            "JobExecutor",
            "RetryCount",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Type",
            "retryCount",
            { "label": "retryCount" }
          ],
          [
            "JobExecutor",
            "RetryCount",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Type",
            "timeout",
            { "label": "timeout" }
          ],
          [
            "JobExecutor",
            "RetryCount",
            "Namespace",
            "$namespace",
            "PodName",
            "$executoragent",
            "Type",
            "error",
            { "label": "error" }
          ]
        ]
      }
