          ],
          [
            "SimpheraService",
            "MethodDurationSecondsCount",
            "Namespace",
            "$namespace",
            "PodName",
            "scbtservice.*",
            "Method",
            "updateJob",
            { "id": "count_update", "visible": false }
          ],
          [
            {
              "expression": "sum_update / count_update",
              "label": "updateJob",
              "id": "avg_update"
            }
          ]
        ]
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 82,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# DRT"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 83,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Job Events Queue",
        "view": "bar",
        "region": "eu-central-1",
        "period": 300,
        "stat": "Sum",
        "stacked": false,
        "legend": {
          "position": "right"
        },
        "metrics": [
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,event_name} MetricName=\"drtservice_job_events_total\" namespace=\"$namespace\"', 'Sum', 300)",
              "label": "$${event_name}",
              "id": "events"
            }
          ],
          [
            {
              "expression": "SUM(events)",
              "label": "Total",
              "id": "total",
              "color": "#d62728"
            }
          ]
        ],
        "yAxis": {
          "left": {
            "min": 0
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 6,
      "y": 83,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Job Events Queue Count",
        "view": "timeSeries",
        "region": "${region}",
        "period": 300,
        "stat": "Sum",
        "stacked": true,
        "legend": {
          "position": "right"
        },
        "metrics": [
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,event_name} MetricName=\"drtservice_job_events_total\" namespace=\"${cluster_name}\"', 'Sum', 300)",
              "label": "$${event_name}",
              "id": "events"
            }
          ]
        ],
        "yAxis": {
          "left": {
            "min": 0
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 90,
      "width": 18,
      "height": 6,
      "properties": {
        "title": "Average Method Duration",
        "view": "timeSeries",
        "region": "${region}",
        "period": 300,
        "stat": "Sum",
        "stacked": false,
        "legend": {
          "position": "right"
        },
        "metrics": [
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,method,pod_name,parent} MetricName=\"simphera_service_method_duration_seconds_sum\" namespace=\"${cluster_name}\" pod_name=\"datareplaybusinesslogic.*\" parent=\"\"', 'Sum', 300)",
              "id": "s",
              "label": "$${method} sum"
            }
          ],
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,method,pod_name,parent} MetricName=\"simphera_service_method_duration_seconds_count\" namespace=\"${cluster_name}\" pod_name=\"datareplaybusinesslogic.*\" parent=\"\"', 'Sum', 300)",
              "id": "c",
              "label": "$${method} count"
            }
          ],
          [
            {
              "expression": "s / c",
              "label": "$${method}",
              "id": "avg"
            }
          ]
        ],
        "yAxis": {
          "left": {
            "min": 0,
            "label": "Seconds"
          }
        }
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 97,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Total execution time"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 98,
      "width": 10,
      "height": 12,
      "properties": {
        "title": "Total Execution Time",
        "view": "pie",
        "region": "${region}",
        "period": 300,
        "stat": "Sum",
        "legend": {
          "position": "right"
        },
        "metrics": [
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,method} MetricName=\"jobexecutor_method_duration_seconds_sum\" namespace=\"${cluster_name}\" method!=\"Total\"', 'Sum', 300)",
              "id": "methods",
              "label": "$${method}"
            }
          ],
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace} MetricName=\"jobexecutor_plugin_duration_seconds_sum\" namespace=\"${cluster_name}\"', 'Sum', 300)",
              "id": "plugins",
              "label": "Plugins",
              "color": "#2d8745"
            }
          ],
          [
            {
              "expression": "SEARCH('{Prometheus/AMP,namespace,method} MetricName=\"jobexecutor_method_duration_seconds_sum\" namespace=\"${cluster_name}\" method=\"Total\"', 'Sum', 300)",
              "id": "total"
            }
          ],
          [
            {
              "expression": "total - (SUM(methods) + plugins)",
              "id": "other",
              "label": "Other",
              "color": "#a0a0a0"
            }
          ]
        ]
      }
    }
  ]
}
