      }
    },
    {
      "type": "log",
      "x": 6,
      "y": 51,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Agent Events Queue",
        "region": "eu-central-1",
        "view": "timeSeries",
        "query": "SOURCE '/aws/containerinsights/mariog-simphera/prometheus' | fields @timestamp, jobscheduler_agent_events_total, event_name\n| filter ispresent(jobscheduler_agent_events_total)\n| stats sum(jobscheduler_agent_events_total) by bin(1m), event_name"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 51,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Agent Events Queue Count",
        "view": "singleValue",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SUM(SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName} MetricName=\"jobscheduler_agent_events_total\" AND Namespace=\"simphera\"', 'Sum', 60))",
              "id": "total_agent_events",
              "label": "Total Events",
              "period": 60
            }
          ]
        ],
        "sparkline": true
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 57,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Jobs Assigned to Agents Count",
        "view": "singleValue",
        "region": "eu-central-1",
        "metrics": [
          [
            {
              "expression": "SUM(SEARCH('{ContainerInsights/Prometheus,Namespace,ServiceName} MetricName=\"jobscheduler_matches_total\" AND Namespace=\"simphera\"', 'Sum', 60))",
              "id": "matches",
              "label": "Matches",
              "period": 60
            }
          ]
        ]
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 63,
      "width": 18,
      "height": 6,
      "properties": {
        "title": "Average Method Duration",
        "region": "eu-central-1",
        "view": "timeSeries",
        "query": "SOURCE '/aws/containerinsights/mariog-simphera/prometheus'\n| fields @timestamp, simphera_service_method_duration_seconds_sum, simphera_service_method_duration_seconds_count, method, PodName\n| filter ispresent(simphera_service_method_duration_seconds_sum)\n  and ispresent(simphera_service_method_duration_seconds_count)\n  and PodName like /jobschedulerservice/\n| stats\n    sum(simphera_service_method_duration_seconds_sum)\n    / sum(simphera_service_method_duration_seconds_count)\n    as avg_duration\n  by bin(1m), method"
      }
    },
    {
      "type": "log",
      "x": 6,
      "y": 57,
      "width": 6,
      "height": 6,
      "properties": {
        "title": "Jobscheduler Avg Method Duration",
        "region": "eu-central-1",
        "view": "timeSeries",
        "query": "SOURCE '/aws/containerinsights/mariog-simphera/prometheus' | fields @timestamp, simphera_service_method_duration_seconds_sum, simphera_service_method_duration_seconds_count, method, PodName\n| filter ispresent(simphera_service_method_duration_seconds_sum) and PodName like /jobschedulerservice/\n| stats sum(simphera_service_method_duration_seconds_sum) / sum(simphera_service_method_duration_seconds_count) as avg_duration by bin(1m), method"
      }
    },
    {
