      "y": 76,
      "width": 18,
      "height": 6,
      "properties": {
        "view": "timeSeries",
        "region": "eu-central-1",
        "stacked": false,
        "title": "Average Method Duration",
        "period": 60,
        "stat": "Sum",
        "legend": {
          "position": "right"
        },
        "metrics": [
          [
            "SimpheraService",
            "MethodDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "scbtservice.*",
            "Method",
            "createJob",
            { "id": "sum_create", "visible": false }
          ],
          [
            "SimpheraService",
            "MethodDurationSecondsCount",
            "Namespace",
            "$namespace",
            "PodName",
            "scbtservice.*",
            "Method",
            "createJob",
            { "id": "count_create", "visible": false }
          ],
          [
            {
              "expression": "sum_create / count_create",
              "label": "createJob",
              "id": "avg_create"
            }
          ],
          [
            "SimpheraService",
            "MethodDurationSecondsSum",
            "Namespace",
            "$namespace",
            "PodName",
            "scbtservice.*",
            "Method",
            "updateJob",
