      "x": 0,
      "y": 41,
      "width": 24,
      "height": 9,
      "properties": {
        "region": "eu-central-1",
        "title": "Logs Panel",
        "query": [
          {
            "logGroupNames": ["/aws/container/jobexecutor"],
