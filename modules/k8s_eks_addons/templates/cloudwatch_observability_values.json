{
    "agent": {
        "config": {
            "agent": {
                "region": "${region}"
            },
            "logs": {
                "metrics_collected": {
                    "application_signals": {
                        "hosted_in": "${cluster_name}"
                    },
                    "kubernetes": {
                        "cluster_name": "${cluster_name}",
                        "enhanced_container_insights": true
                    }
                }
            },
            "traces": {
                "traces_collected": {
                    "application_signals": {}
                }
            }
        }
    }
}